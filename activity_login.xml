<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/bg_dark"
    android:padding="32dp">

    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_shield"
        android:contentDescription="Lock icon"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/tvLoginTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PIN डालें"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:layout_marginBottom="32dp" />

    <!-- PIN dot display -->
    <TextView
        android:id="@+id/tvPinDots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="○ ○ ○ ○"
        android:textSize="40sp"
        android:textColor="@color/white"
        android:letterSpacing="0.15"
        android:layout_marginBottom="40dp" />

    <!-- Row 1 -->
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="12dp">
        <Button android:id="@+id/btn1" style="@style/PinButton" android:text="1" />
        <Button android:id="@+id/btn2" style="@style/PinButton" android:text="2" android:layout_marginHorizontal="12dp" />
        <Button android:id="@+id/btn3" style="@style/PinButton" android:text="3" />
    </LinearLayout>

    <!-- Row 2 -->
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="12dp">
        <Button android:id="@+id/btn4" style="@style/PinButton" android:text="4" />
        <Button android:id="@+id/btn5" style="@style/PinButton" android:text="5" android:layout_marginHorizontal="12dp" />
        <Button android:id="@+id/btn6" style="@style/PinButton" android:text="6" />
    </LinearLayout>

    <!-- Row 3 -->
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="12dp">
        <Button android:id="@+id/btn7" style="@style/PinButton" android:text="7" />
        <Button android:id="@+id/btn8" style="@style/PinButton" android:text="8" android:layout_marginHorizontal="12dp" />
        <Button android:id="@+id/btn9" style="@style/PinButton" android:text="9" />
    </LinearLayout>

    <!-- Row 4: Clear | 0 | Backspace -->
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/btnClear" style="@style/PinButton" android:text="C"
            android:backgroundTint="@color/error_red" />
        <Button android:id="@+id/btn0" style="@style/PinButton" android:text="0"
            android:layout_marginHorizontal="12dp" />
        <Button android:id="@+id/btnBackspace" style="@style/PinButton" android:text="⌫"
            android:backgroundTint="@color/gray_600" />
    </LinearLayout>

</LinearLayout>
