<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:ads="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- ── Header ─────────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="@color/bg_dark_secondary">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/accent_gold" />

        <TextView
            android:id="@+id/tvPremiumBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⭐ PREMIUM"
            android:textSize="11sp"
            android:textColor="@color/accent_gold"
            android:background="@drawable/bg_premium_badge"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- ── Feature Buttons ───────────────────────────────────────────────── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button
                android:id="@+id/btnNormalDocs"
                style="@style/HomeButton"
                android:text="📁  Normal Documents"
                android:backgroundTint="@color/btn_blue" />

            <Button
                android:id="@+id/btnPrivateDocs"
                style="@style/HomeButton"
                android:text="🔐  Private Documents"
                android:backgroundTint="@color/btn_gold"
                android:textColor="@color/black" />

            <Button
                android:id="@+id/btnQrScan"
                style="@style/HomeButton"
                android:text="📷  QR Scan &amp; Save"
                android:backgroundTint="@color/btn_green" />

            <Button
                android:id="@+id/btnBackup"
                style="@style/HomeButton"
                android:text="☁️  Backup"
                android:backgroundTint="@color/btn_purple" />

            <!-- Upgrade Banner (hidden for premium) -->
            <LinearLayout
                android:id="@+id/btnUpgradePremium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_upgrade_banner"
                android:padding="16dp"
                android:gravity="center"
                android:layout_marginTop="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ Upgrade to Premium"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_gold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No Ads • Encrypted Folder • Backup"
                    android:textSize="12sp"
                    android:textColor="@color/white_70" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ── AdMob Banner (bottom, free users only) ─────────────────────────── -->
    <com.google.android.gms.ads.AdView
        android:id="@+id/adViewHome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        ads:adSize="BANNER"
        ads:adUnitId="ca-app-pub-3940256099942544/6300978111" />

</LinearLayout>
