<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Internet (AdMob + Billing के लिए जरूरी) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Camera (QR Scanner के लिए) -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Storage (File Upload के लिए) -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_DOCUMENTS" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />

    <!-- Biometric (Private Folder के लिए) -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />

    <!-- Billing -->
    <uses-permission android:name="com.android.vending.BILLING" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RYKSecretLocker"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- AdMob App ID (Test ID — Production में अपना ID डालें) -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-3940256099942544~3347511713" />

        <!-- ML Kit Barcode Model Download -->
        <meta-data
            android:name="com.google.mlkit.vision.DEPENDENCIES"
            android:value="barcode_ui" />

        <!-- SplashActivity (Launcher) -->
        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:noHistory="true"
            android:theme="@style/Theme.RYKSecretLocker.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- LoginActivity -->
        <activity android:name=".ui.LoginActivity" android:exported="false" />

        <!-- HomeActivity -->
        <activity android:name=".ui.HomeActivity" android:exported="false" />

        <!-- NormalFolderActivity -->
        <activity android:name=".ui.NormalFolderActivity" android:exported="false" />

        <!-- PrivateFolderActivity -->
        <activity android:name=".ui.PrivateFolderActivity" android:exported="false" />

        <!-- ScannerActivity -->
        <activity android:name=".ui.ScannerActivity" android:exported="false" />

        <!-- BackupActivity -->
        <activity android:name=".ui.BackupActivity" android:exported="false" />

    </application>

</manifest>
