<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base Theme -->
    <style name="Base.Theme.RYKSecretLocker" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="colorPrimaryVariant">@color/card_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_gold</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Theme.RYKSecretLocker" parent="Base.Theme.RYKSecretLocker" />

    <!-- Splash Theme (Full Screen) -->
    <style name="Theme.RYKSecretLocker.Splash" parent="Base.Theme.RYKSecretLocker">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <!-- PIN Button Style -->
    <style name="PinButton">
        <item name="android:layout_width">72dp</item>
        <item name="android:layout_height">72dp</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:backgroundTint">@color/bg_dark_secondary</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Dashboard Card Style -->
    <style name="DashboardCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">20dp</item>
        <item name="android:gravity">start</item>
    </style>

    <!-- Premium Dialog -->
    <style name="PremiumDialog" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="colorPrimary">@color/accent_gold</item>
        <item name="android:windowBackground">@color/bg_dark_secondary</item>
        <item name="android:textColor">@color/white</item>
    </style>

</resources>
